# Your site URL (used for sitemap, robots.txt, metadata, OG images)
# Example: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=

# Calendly booking link (optional - hides "Book a 15-min intro call" if not set)
# Example: https://calendly.com/your-username/15min
NEXT_PUBLIC_CALENDLY_URL=

# Availability badge in hero (optional - defaults to "available")
# Options: available | exploring | employed
NEXT_PUBLIC_AVAILABILITY_STATUS=
